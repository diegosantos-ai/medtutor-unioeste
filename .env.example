# ==============================================================================
# Variáveis de Ambiente Base (Template)
# Substitua as chaves abaixo e renomeie este arquivo para .env.
# ATENÇÃO: NUNCA comite o .env real para não violar as regras de Shift-Left Security.
# ==============================================================================

# ------------------------------
# Backend & Persistência
# ------------------------------
# Conexão com banco de dados PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/medtutor_db

# Serviços de Cache/Busca (Redis / Chroma)
REDIS_URL=redis://localhost:6379
CHROMA_URL=http://localhost:8000

# ------------------------------
# Inteligência Artificial
# ------------------------------
# Obtenha no manifesto ou crie a sua chave no painel do Google AI Studio
GEMINI_API_KEY=sua_chave_secreta_aqui

# ------------------------------
# Frontend (Opcional pra Dev local)
# ------------------------------
VITE_API_URL=http://localhost:8096/api
